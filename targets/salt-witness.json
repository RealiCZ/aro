{
  "name": "salt-witness",
  "target_repo": {
    "path": "/nvme2/mega-engineer/workspace/salt",
    "baseline_ref": "19419f4d13e6c615b7a94cf3d2bf53d1052f723c"
  },
  "hot_path": {
    "file": "salt/src/proof/witness.rs",
    "fn": "create"
  },
  "metric": "ns_per_call",
  "direction": "minimize",
  "icount_epsilon_pct": 0.02,
  "benchmark_probe": {
    "pkg": "salt",
    "probe": "probes/salt_witness.rs",
    "example": "salt_witness",
    "sample_prefix": "BENCH",
    "profile": {
      "spin_secs": 6,
      "sample_secs": 4
    }
  },
  "correctness_oracle": {
    "build": [
      "cargo",
      "build",
      "--release",
      "-p",
      "salt"
    ],
    "test": [
      "cargo",
      "test",
      "-p",
      "salt"
    ],
    "test_full": [
      "cargo",
      "test"
    ],
    "differential": {
      "pkg": "salt",
      "probe": "probes/salt_witness_diff.rs",
      "example": "salt_witness_diff",
      "prefix": "DIFF"
    }
  },
  "constraints": {
    "editable": [
      "salt/src/proof/witness.rs",
      "salt/src/proof/salt_witness.rs",
      "salt/src/proof/prover.rs",
      "salt/src/proof/subtrie.rs",
      "salt/src/proof/shape.rs",
      "salt/src/state/state.rs",
      "salt/src/state/hasher.rs",
      "salt/src/state/updates.rs",
      "salt/src/trie/node_utils.rs",
      "salt/src/trie/trie.rs",
      "ipa-multipoint/src/multiproof.rs",
      "ipa-multipoint/src/ipa.rs",
      "ipa-multipoint/src/lagrange_basis.rs",
      "ipa-multipoint/src/math_utils.rs",
      "ipa-multipoint/src/transcript.rs",
      "banderwagon/src/element.rs",
      "banderwagon/src/msm.rs",
      "banderwagon/src/salt_committer.rs",
      "banderwagon/src/scalar_multi_asm.rs"
    ],
    "no_new_deps": true,
    "byte_identical": true,
    "notes": "Production stateless-validation analogue: build and persist deterministic account/storage state and trie, derive explicit bucket metadata reads, create Witness over existing/missing lookups plus update/delete/insert writes, verify its Salt/IPA proof, read from it, and replay the transition/root. Timed and differential probes use identical workload() and run_once(). Differential fingerprints BTree-ordered Salt KVs, uncompressed parent commitments, explicitly BucketId-sorted levels, canonical cryptographic multipoint proof bytes, state root, verify result, ordered lookup results, replay StateUpdates, next root, and NodeId-sorted TrieUpdates. Editable paths are only co-reached Salt/IPA/banderwagon proof/state/crypto implementation files; serde wire compression and base64 wrappers are excluded."
  },
  "run": {
    "generator": "agentic",
    "aa_runs": 2,
    "ab_pairs": 6,
    "timeout": 1800,
    "bench_scales": [
      1,
      8
    ]
  },
  "probe_covers": [
    "salt/src/proof/witness.rs",
    "salt/src/proof/salt_witness.rs",
    "salt/src/proof/prover.rs",
    "salt/src/proof/subtrie.rs",
    "salt/src/proof/shape.rs",
    "salt/src/state/state.rs",
    "salt/src/state/hasher.rs",
    "salt/src/state/updates.rs",
    "salt/src/trie/node_utils.rs",
    "salt/src/trie/trie.rs",
    "ipa-multipoint/src/multiproof.rs",
    "ipa-multipoint/src/ipa.rs",
    "ipa-multipoint/src/lagrange_basis.rs",
    "ipa-multipoint/src/math_utils.rs",
    "ipa-multipoint/src/transcript.rs",
    "banderwagon/src/element.rs",
    "banderwagon/src/msm.rs",
    "banderwagon/src/salt_committer.rs",
    "banderwagon/src/scalar_multi_asm.rs"
  ],
  "llm_backend": "codex",
  "pinned_tools": {
    "codspeed": "4.18.3",
    "cargo-codspeed": "5.0.1",
    "valgrind": "3.26.0.codspeed5",
    "rustc": "1.96.0"
  },
  "profile_fidelity": "repo-release",
  "terminal_lane": "probe",
  "terminal_probe_scales": [
    1,
    8
  ],
  "ship_target": "origin/main",
  "ship_conformance": [
    {
      "name": "check",
      "cmd": "cargo check --all-targets"
    },
    {
      "name": "cargo-sort",
      "cmd": "cargo sort --check --workspace --grouped --order package,workspace,lints,profile,bin,benches,dependencies,dev-dependencies,features"
    },
    {
      "name": "test",
      "cmd": "cargo test"
    },
    {
      "name": "test-bucket-resize",
      "cmd": "NUM_DATA_BUCKETS=2 BUCKET_RESIZE_LOAD_FACTOR_PCT=1 cargo test --features test-bucket-resize -- --test-threads=4"
    },
    {
      "name": "random-stress",
      "cmd": "NUM_DATA_BUCKETS=2 BUCKET_RESIZE_LOAD_FACTOR_PCT=80 RANDOM_KV_POOL_SIZE=4096 RANDOM_ITERATIONS=100 RANDOM_BLOCKS=3 RANDOM_MINI_BLOCKS=10 RANDOM_OPS=100 RANDOM_LOOKUPS=50 cargo test -p salt --features test-bucket-resize test_e2e_random_stress -- --ignored --nocapture"
    },
    {
      "name": "no-std-check",
      "cmd": "cargo +nightly check -p salt --target riscv64imac-unknown-none-elf --no-default-features"
    },
    {
      "name": "no-default-features-test",
      "cmd": "cargo +nightly test --no-default-features"
    },
    {
      "name": "no-default-features-resize-test",
      "cmd": "cargo +nightly test --no-default-features --features test-bucket-resize"
    },
    {
      "name": "fmt",
      "cmd": "cargo fmt --all -- --check"
    },
    {
      "name": "clippy",
      "cmd": "cargo clippy --all-targets -- -D warnings"
    }
  ]
}
