{
  "name": "evm-auto",
  "repo": "/path/to/mega-evm",
  "baseline_ref": "HEAD",
  "build": ["cargo", "build", "--release", "-p", "mega-evm"],
  "test": ["cargo", "test", "--release", "-p", "mega-evm", "--lib"],
  "bench": {
    "probe": "probes/evm_auto.rs",
    "example": "evm_auto",
    "pkg": "mega-evm",
    "sample_prefix": "BENCH",
    "metric": "ns_per_call"
  },
  "profile": {"example": "evm_auto", "spin_secs": 8, "sample_secs": 4},
  "regions": ["crates/mega-evm/src/limit/state_growth.rs"],
  "context": {
    "file": "crates/mega-evm/src/limit/state_growth.rs",
    "anchors": [["fn", "check_limit"]]
  },
  "objectives": [{"metric": "ns_per_call", "minimize": true}],
  "goal": {"metric": "ns_per_call", "direction": "minimize", "target": null},
  "stop": {"max_rounds": 1, "dry_rounds": 1},
  "prompts": {"agentic": "agentic", "hint": "hint", "hint_blind": "hint_blind"},
  "generator": "agentic",
  "differential": {
    "probe": "probes/evm_auto_diff.rs",
    "pkg": "mega-evm",
    "example": "evm_auto_diff",
    "prefix": "DIFF"
  },
  "timeout": 900
}
