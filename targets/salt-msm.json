{
  "name": "salt-msm",

  "target_repo":  { "path": "/Users/cz/work/salt", "baseline_ref": "HEAD" },
  "hot_path":     { "file": "banderwagon/src/salt_committer.rs", "fn": "mul_index" },
  "metric":       "ns_per_call",
  "direction":    "minimize",

  "benchmark_probe": {
    "pkg": "banderwagon",
    "probe": "probes/salt_msm.rs",
    "example": "salt_msm",
    "sample_prefix": "BENCH",
    "profile": { "spin_secs": 6, "sample_secs": 4 }
  },

  "correctness_oracle": {
    "build": ["cargo", "build", "--release", "-p", "banderwagon"],
    "test":  ["cargo", "test", "-p", "banderwagon", "--lib"],
    "differential": { "pkg": "banderwagon", "probe": "probes/salt_msm_diff.rs", "example": "salt_msm_diff", "prefix": "DIFF" }
  },

  "constraints": {
    "editable": ["banderwagon/src/salt_committer.rs"],
    "no_new_deps": true,
    "byte_identical": true,
    "notes": "Committer::mul_index wNAF scalar-mul hot path (precompute table + point adds)"
  },

  "run": {
    "generator": "agentic",
    "stop": { "max_rounds": 1, "dry_rounds": 1 },
    "aa_runs": 2,
    "ab_pairs": 6,
    "timeout": 1800,
    "bench_scales": [1, 8, 64]
  }
}
