  "correctness_oracle": {
    "build": [
      "cargo",
      "build",
      "--release",
      "-p",
      "banderwagon"
    ],
    "test": [
      "cargo",
      "test",
      "-p",
      "banderwagon",
      "-p",
      "ipa-multipoint"
    ],
    "test_full": [
      "cargo",
      "test",
      "--workspace"
    ],
    "differential": {
      "pkg": "banderwagon",
      "probe": "probes/salt_msm_diff.rs",
      "example": "salt_msm_diff",
      "prefix": "DIFF"
    }
  },
  "constraints": {
    "editable": [
      "banderwagon/src"
    ],
    "no_new_deps": true,
    "byte_identical": true,
    "notes": "Committer::mul_index wNAF scalar-mul hot path (precompute table + point adds)"
