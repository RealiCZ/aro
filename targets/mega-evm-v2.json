{
  "name": "mega-evm-v2",
  "target_repo":  { "path": "/home/mega-engineer/workspace/mega-evm-aro",
                    "baseline_ref": "996c16a91d071e3bb95780ea7dc5d4f1677bf746" },
  "ship_target": "origin/cz/feat/rex6-preview",
  "hot_path":     { "file": "crates/mega-evm/src/evm/host.rs", "fn": "inspect_storage" },
  "metric":       "ns_per_call",
  "direction":    "minimize",

  "benchmark_probe": {
    "pkg": "mega-evm",
    "probe": "probes/sweep_hotloop_v2.rs",
    "example": "sweep_hotloop_v2",
    "sample_prefix": "BENCH",
    "profile": { "example": "sweep_hotloop_v2", "spin_secs": 10, "sample_secs": 5 }
  },

  "correctness_oracle": {
    "build": ["cargo", "build", "--release", "-p", "mega-evm"],
    "test":  ["cargo", "test", "--release", "-p", "mega-evm", "--lib"],
    "test_full": ["cargo", "test", "--release", "-p", "mega-evm"],
    "differential": { "pkg": "mega-evm", "probe": "probes/evm_semantics_diff.rs",
                      "example": "evm_semantics_diff", "prefix": "DIFF" }
  },

  "constraints": {
    "editable": ["crates/mega-evm/src"],
    "no_new_deps": true,
    "byte_identical": true
  },

  "probe_covers": ["crates/mega-evm/src"],
  "icount_epsilon_pct": 0.01,

  "terminal_bench_targets": ["mega_bench"],
  "measure_bin": "/home/mega-engineer/workspace/mega-bench-reporter/target/release/mega-bench-reporter",
  "control_lanes": ["revm_pinned", "revm_latest", "op_revm_pinned", "op_revm_latest"],
  "protected_row_families": [
    "oracle_sload", "sstore_heavy", "call_value_empty_account", "mixed_workload"
  ],
  "tradeable_regression_cap_pct": 1.0,
  "protected_hysteresis": { "margin_pp": 0.05, "floor_multiple": 1.5 },

  "llm_backend": "codex",
  "run": { "generator": "agentic", "aa_runs": 2, "ab_pairs": 8,
           "timeout": 1800, "bench_scales": [1, 8, 64] },
  "pinned_tools": { "codspeed": "4.18.3", "cargo-codspeed": "5.0.1",
                    "valgrind": "3.26.0.codspeed5", "rustc": "1.96.0" },
  "control_composition_bound_pct": 5.0,

  "ship_conformance": [
    {"name": "fmt",  "cmd": "cargo fmt --all --check"},
    {"name": "clippy", "cmd": "cargo clippy --workspace --lib --examples --tests --benches --all-features --locked"},
    {"name": "test", "cmd": "cargo test --release -p mega-evm"}
  ]
}
