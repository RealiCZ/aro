+    <div class="right">
+      <span id="mast-stats"></span>
+      <span class="livepill" id="livepill"><span class="livedot"></span><span id="livetext">LIVE</span></span>
+    </div>
+  </div>
+  <div class="hero">
+    <div class="bank">
+      <div class="eyebrow">banked · in your pocket now <s>judge-proven, patches on disk</s></div>
+      <div class="bignum" id="bignum"></div>
+      <div class="banksub" id="banksub"></div>
+      <div class="chips" id="provchips"></div>
+    </div>
+    <div class="now" id="nowpanel">
+      <div class="eyebrow"><span class="livedot" id="nowdot"></span><span id="nowtitle">judge is running</span></div>
+      <div id="nowrows"></div>
+    </div>
+  </div>
+</div></header>
+
+<div class="wrap">
+  <section>
+    <div class="plate">Where the time stands <s>conservation: the segments always sum to ~100%</s></div>
+    <div class="consv"><div class="cbar" id="cbar"></div><div class="clegend" id="clegend"></div></div>
+  </section>
+
+  <section>
+    <div class="plate">Convergence <s>realized climbs, headroom falls: the pinch is exhaustion</s></div>
+    <div class="chartbox">
+      <svg id="scissors" viewBox="0 0 1040 340"></svg>
+      <div class="chlegend">
+        <span><i class="line" style="border-color:var(--gold)"></i>realized (% faster, compounded)</span>
+        <span><i class="line" style="border-color:var(--live)"></i>addressable headroom (%)</span>
+        <span><i class="diamond"></i>micro-proven fold (probe rescue)</span>
+        <span><i class="line" style="border-color:var(--floorink);border-top-style:dashed"></i>untouchable floor</span>
+      </div>
+    </div>
+  </section>
+
+  <section>
+    <div class="plate">The permanent tree <s>every branch gets a terminal verdict: click a node for its dossier</s></div>
+    <div class="treegrid">
+      <div class="tree" id="tree"></div>
+      <aside class="dossier" id="dossier"></aside>
+    </div>
+  </section>
+
+  <section id="proofsec">
+    <div class="plate">Exhaustion proof <s>all three boundaries closed = nothing provable left</s></div>
+    <div class="proof" id="proof"></div>
+  </section>
+
+  <section id="perfsec" style="display:none">
+    <div class="plate">Speedup vs spend <s>running best vs cumulative LLM output tokens</s></div>
+    <div class="perfsvg" id="perfsvg"></div>
+  </section>
+
+  <div class="foot">
+    <span>truth · <b>events.jsonl</b>: every number verbatim, verdicts never re-judged</span>
+    <span>anytime · stop at any moment, the banked column is already yours</span>
+    <span><b>ARO</b> · the loop is commodity · the judge is the moat</span>
+  </div>
+</div>
+
+<script>
+const D = window.__ARO_DATA__ || {spec:"(no data)", summary:{}, nodes:[], trajectory:[],
+                                  provenance:{}, closure:null, live:{running:false}};
+const S = D.summary || {};
+const esc = s => String(s ?? "").replace(/&/g,"&amp;").replace(/</g,"&lt;").replace(/>/g,"&gt;");
+const fmt = (x, d=1) => (typeof x === "number" && isFinite(x)) ? x.toFixed(d) : "-";
+
+/* ---------------- verdict chips ---------------- */
+const VMAP = {
+  accepted:      ["accepted ✓","v-accepted"],
+  "micro-proven":["micro-proven","v-micro"],
+  "within-noise":["within-noise","v-noise"],
+  "noise-limited":["pending · noise-limited","v-pending"],
+  regressed:     ["regressed","v-bad"],
+  "parent-regressed":["parent-regressed","v-bad"],
+  "verify-failed":["verify-failed","v-bad"],
+  "build-failed":["build-failed","v-bad"],
+  rejected:      ["critic-reject","v-bad"],
+  unlocated:     ["unlocated","v-floor"],
+  errored:       ["errored","v-bad"],
+  running:       ["benching ●","v-live"],
+  "no-candidate":["no candidate","v-noise"],
+};
+function vchip(node){
+  const key = (node.regime === "micro-proven" && node.accepted) ? "micro-proven"
+            : (node.status || node.verdict || "no-candidate");
+  const [label, cls] = VMAP[key] || [key, "v-noise"];
+  return `<span class="vchip ${cls}">${esc(label)}</span>`;
+}
+function fmtD(d){ return (typeof d === "number" && isFinite(d)) ? (d>0?"+":"")+d.toFixed(1)+"%" : "-"; }
+
+/* ---------------- masthead / hero ---------------- */
+const realized = S.realized_pct ?? 0;           // (1 - Π(1+Δ/100)) · 100: the share of
+                                                // original run time REMOVED (verbatim)
+const speedup = realized < 100 ? (1 / (1 - realized/100)) : Infinity;  // throughput multiple
+document.title = `ARO · ${D.spec} · exhaustion ledger`;
+document.getElementById("mast-stats").textContent =
+  `${D.spec} · ${S.attempted ?? 0} attempted · ${S.accepted ?? 0} won` +
+  (S.tokens ? ` · ${(S.tokens/1e6).toFixed(2)}M tok` : "") +
+  (S.cost_usd ? ` · $${S.cost_usd}` : "");
+const running = !!(D.live && D.live.running);
+document.getElementById("livepill").className = "livepill" + (running ? "" : " done");
+document.getElementById("livetext").textContent = running ? "LIVE · events.jsonl" : "RUN COMPLETE";
+document.getElementById("bignum").innerHTML =
+  `<b>${fmt(realized)}<small>%</small></b> <small>of run time reclaimed · ${S.accepted ?? 0} wins compounded</small>`;
+document.getElementById("banksub").innerHTML =
+  `≈ <b>×${isFinite(speedup) ? fmt(speedup, 2) : "∞"}</b> throughput · decision <b>${esc(S.decision ?? "?")}</b>`;
+const P = D.provenance || {};
+document.getElementById("provchips").innerHTML = [
+  `<span class="chip"><i style="background:var(--good)"></i><b>${P.mergeable ?? 0}</b> byte-identical · mergeable</span>`,
+  `<span class="chip"><i style="background:var(--gold)"></i><b>${P.micro ?? 0}</b> micro-proven · parent-checked</span>`,
+  `<span class="chip"><i style="background:var(--violet)"></i><b>${P.needs_call ?? 0}</b> needs your call</span>`,
+].join("");
+
+/* ---------------- NOW strip ---------------- */
+const nowRows = [];
+if (running){
+  nowRows.push(["node", esc(D.live.last_fn || "…")]);
+  nowRows.push(["last gate", esc(D.live.last_gate || "…")]);
+  nowRows.push(["last event", esc(D.live.last_event || "…")]);
+} else {
+  document.getElementById("nowpanel").classList.add("done");
+  document.getElementById("nowdot").style.display = "none";
+  document.getElementById("nowtitle").textContent = "campaign state";
+  nowRows.push(["decision", esc(S.decision ?? "?")]);
+  if (S.reason) nowRows.push(["why", esc(S.reason)]);
+  nowRows.push(["headroom left", fmt(S.headroom_pct) + "%"]);
+  if (S.critic_rejects) nowRows.push(["critic rejects", S.critic_rejects]);
+}
+document.getElementById("nowrows").innerHTML =
+  nowRows.map(([k,v]) => `<div class="nowrow"><span>${k}</span><b>${v}</b></div>`).join("");
+
+/* ---------------- conservation bar ---------------- */
+const FILL = {captured:"var(--gold)", headroom:"var(--live)", tried:"#9aa7b3",
+              unreachable:null, floor:null, other:"#e6ebf1"};
+const HATCH = {unreachable:"hatch", floor:"hatch2"};
+const segs = (S.coverage || []).filter(s => (s.pct ?? 0) > 0);
+document.getElementById("cbar").innerHTML = segs.map(s => {
+  const fill = FILL[s.key];
+  const cls = "cseg" + (fill ? "" : " dim " + (HATCH[s.key] || ""));
+  const style = (fill ? `background:${fill};` : "") + `flex:${s.pct}`;
+  const label = s.pct >= 4.5 ? `<span class="pct">${s.pct}%</span>` : "";
+  return `<div class="${cls}" style="${style}" title="${esc(s.label)} · ${s.pct}%">${label}</div>`;
+}).join("");
+document.getElementById("clegend").innerHTML = segs.map(s => {
+  const fill = FILL[s.key];
+  const swatch = fill ? `style="background:${fill}"` :
+    `class="${HATCH[s.key]||''}" style="border:1px solid var(--rule2)"`;
+  return `<span><i ${swatch}></i>${esc(s.label)} ${s.pct}%</span>`;
+}).join("");
+
+/* ---------------- convergence chart ---------------- */
+(function(){
+  const svg = document.getElementById("scissors"), NS = "http://www.w3.org/2000/svg";
+  const T = (D.trajectory || []).filter(t => typeof t.i === "number");
+  const W=1040,H=340,L=52,R=18,Tp=18,B=42;
+  const el=(t,at,parent)=>{const e=document.createElementNS(NS,t);for(const k in at)e.setAttribute(k,at[k]);(parent||svg).appendChild(e);return e};
+  if (!T.length){
+    el("text",{x:W/2,y:H/2,"text-anchor":"middle",fill:"#8391a0","font-size":13,
+               "font-family":"ui-monospace"}).textContent = "no explorer steps recorded (run with --diverge)";
+    return;
+  }
+  const xmax = Math.max(...T.map(t=>t.i), 1);
+  const floor = S.floor_pct ?? 0;
+  const ymax = Math.max(10, floor*1.15, ...T.map(t=>Math.max(t.realized??0, t.headroom??0))) * 1.1;
+  const X=a=>L+(W-L-R)*a/xmax, Y=v=>Tp+(H-Tp-B)*(1-v/ymax);
+  const ticks = 4;
+  for(let k=0;k<=ticks;k++){
+    const v = ymax*k/ticks;
+    el("line",{x1:L,x2:W-R,y1:Y(v),y2:Y(v),stroke:"#e2e8ef","stroke-width":1});
+    el("text",{x:L-8,y:Y(v)+4,"text-anchor":"end",fill:"#8391a0","font-size":11,
+               "font-family":"ui-monospace"}).textContent = v.toFixed(0)+"%";
+  }
+  el("text",{x:W-R,y:H-16,"text-anchor":"end",fill:"#8391a0","font-size":11,
+             "font-family":"ui-monospace"}).textContent = `${xmax} attempts →`;
+  if (floor > 0){
+    const defs = el("defs",{});
+    const pat = el("pattern",{id:"ht",width:8,height:8,patternUnits:"userSpaceOnUse",patternTransform:"rotate(45)"},defs);
+    el("line",{x1:0,y1:0,x2:0,y2:8,stroke:"#c6cfd9","stroke-width":3},pat);
+    if (floor < ymax){
+      el("rect",{x:L,y:Tp,width:W-L-R,height:Math.max(0,Y(floor)-Tp),fill:"url(#ht)",opacity:.5});
+      el("line",{x1:L,x2:W-R,y1:Y(floor),y2:Y(floor),stroke:"#9aa6b3","stroke-width":1.5,"stroke-dasharray":"6 5"});
+      el("text",{x:W-R-6,y:Y(floor)-7,"text-anchor":"end",fill:"#6b7885","font-size":11,
+                 "font-family":"ui-monospace"}).textContent = `floor ${fmt(floor,0)}% · untouchable`;
+    }
+  }
+  // headroom: falling line + area
+  let ah=`M${X(T[0].i)},${Y(T[0].headroom??0)}`, area=`M${X(T[0].i)},${Y(0)} L${X(T[0].i)},${Y(T[0].headroom??0)}`;
+  T.forEach(p=>{ah+=` L${X(p.i)},${Y(p.headroom??0)}`;area+=` L${X(p.i)},${Y(p.headroom??0)}`});
+  area+=` L${X(T[T.length-1].i)},${Y(0)} Z`;
+  el("path",{d:area,fill:"rgba(37,150,173,.10)"});
+  el("path",{d:ah,fill:"none",stroke:"var(--live)","stroke-width":2.5,"stroke-linejoin":"round"});
+  // realized: rising staircase
+  let g=`M${X(T[0].i)},${Y(0)}`;
+  let prev = 0;
+  T.forEach(p=>{ g+=` L${X(p.i)},${Y(prev)} L${X(p.i)},${Y(p.realized??prev)}`; prev = p.realized ?? prev; });
+  el("path",{d:g,fill:"none",stroke:"var(--gold)","stroke-width":2.5,"stroke-linejoin":"round"});
+  T.forEach(p=>{
+    if(!p.accepted) return;
+    if(p.regime === "micro-proven"){
+      el("rect",{x:X(p.i)-4.5,y:Y(p.realized??0)-4.5,width:9,height:9,fill:"var(--violet)",
+                 transform:`rotate(45 ${X(p.i)} ${Y(p.realized??0)})`,stroke:"#fff","stroke-width":1.5});
+    } else {
+      el("circle",{cx:X(p.i),cy:Y(p.realized??0),r:4.5,fill:"var(--gold)",stroke:"#fff","stroke-width":2});
+    }
+  });
+  const last = T[T.length-1];
+  el("text",{x:X(last.i)-6,y:Y(last.realized??0)-10,"text-anchor":"end",fill:"var(--gold-t)",
+             "font-size":13,"font-weight":600,"font-family":"ui-monospace"})
+    .textContent = `${fmt(last.realized)}% realized`;
+  el("text",{x:X(last.i)-6,y:Y(last.headroom??0)+18,"text-anchor":"end",fill:"var(--live-t)",
+             "font-size":12,"font-family":"ui-monospace"})
+    .textContent = `${fmt(last.headroom)}% left to hunt`;
+})();
+
+/* ---------------- tree + dossier ---------------- */
+const fnNodes = (D.nodes || []).filter(n => n.type === "fn");
+const skipped = (D.nodes || []).filter(n => n.type === "skipped");
+const treeEl = document.getElementById("tree");
+let selIdx = fnNodes.length ? 0 : -1;
+let selCand = -1;   // -1 = auto (the node's best candidate); >=0 pins one candidate
+
+function renderTree(){
+  let h = `<div class="lanehead"><b>${esc(D.spec)}</b>
+    <span class="prov">workload</span>
+    <span class="share">${fnNodes.length} nodes · ${skipped.length} unlocated</span></div>`;
+  fnNodes.forEach((n, i) => {
+    const d = n.delta;
+    const dcls = (typeof d === "number") ? (d < 0 ? "win" : (d > 0 ? "reg" : "")) : "";
+    h += `<div class="node"><div class="noderow${i===selIdx?" sel":""}" data-i="${i}" role="button" tabindex="0">
+      <span class="tw">${(n.candidates||[]).length ? "▸" : "·"}</span>
+      <span class="fname">${esc(n.fn)}</span><span class="fpct">${fmt(n.pct)}%</span>
+      <span class="spacer"></span>${vchip(n)}
+      <span class="delta ${dcls}">${fmtD(d)}</span></div>`;
+    if (i === selIdx && (n.candidates||[]).length){
+      h += `<div class="kids">` + n.candidates.map((c, j) => {
+        const cd = (c.metrics && c.metrics[0]) ? c.metrics[0].delta_pct : null;
+        return `<div class="noderow${j===selCand?" sel":""}" data-i="${i}" data-c="${j}" role="button" tabindex="0"><span class="tw">└</span>
+          <span class="fname" style="color:var(--ink2)">${esc(c.id)} · ${esc((c.hypothesis||"").split("\n")[0].slice(0,60))}</span>
+          <span class="spacer"></span><span class="vchip ${(VMAP[c.verdict]||["","v-noise"])[1]}">${esc(c.verdict)}</span>
+          <span class="delta">${fmtD(cd)}</span></div>`;
+      }).join("") + `</div>`;
+    }
+    h += `</div>`;
+  });
+  skipped.forEach(n => {
+    h += `<div class="node"><div class="noderow" style="cursor:default">
+      <span class="tw">·</span><span class="fname" style="color:var(--mute)">${esc(n.fn)}</span>
+      <span class="spacer"></span><span class="vchip v-floor">unlocated</span>
+      <span class="delta">-</span></div></div>`;
+  });
+  treeEl.innerHTML = h;
+  treeEl.querySelectorAll(".noderow[data-i]").forEach(row => {
+    const open = () => {
+      const fi = +row.dataset.i;
+      // A fn row selects the node (dossier = its best candidate); a CANDIDATE row
+      // pins that candidate so its own hypothesis/diff/critic audit can be read.
+      selCand = ("c" in row.dataset) ? +row.dataset.c : -1;
+      selIdx = fi;
+      renderTree(); renderDossier(fnNodes[selIdx], selCand);
+    };
+    row.addEventListener("click", open);
+    row.addEventListener("keydown", e => { if (e.key === "Enter" || e.key === " "){ e.preventDefault(); open(); }});
+  });
+}
+
+function diffHtml(text){
+  if (!text) return "";
+  const lines = text.split("\n").map(l => {
+    const cls = l.startsWith("@@") ? "hunk" : l.startsWith("#") ? "hunk"
+              : l.startsWith("+") ? "add" : l.startsWith("-") ? "del" : "ctx";
+    return `<div class="dl ${cls}">${esc(l)}</div>`;
+  }).join("");
+  return `<div class="diff">${lines}</div>`;
+}
+
+function renderDossier(n, cIdx = -1){
+  const doss = document.getElementById("dossier");
+  if (!n){ doss.innerHTML = `<div class="dbody" style="color:var(--mute)">no attempts recorded</div>`; return; }
+  const pinned = (cIdx >= 0 && (n.candidates || [])[cIdx]) || null;
+  const best = pinned
+    || (n.candidates || []).find(c => c.verdict === n.status) || (n.candidates || [])[0] || {};
+  const cd = (best.metrics && best.metrics[0]) ? best.metrics[0].delta_pct : null;
+  const kv = [
+    ["self-time", `${fmt(n.pct)}% of workload`],
+    pinned ? ["candidate Δ", fmtD(cd)]
+           : ["best Δ", fmtD(n.delta) + (n.parent_delta != null ? ` · parent ${fmtD(n.parent_delta)}` : "")],
+    ["regime", esc(n.regime || "-")],
+    ["files", esc((n.files || []).join(", ") || "-")],
+    ["explorer", n.decision ? `${esc(n.decision)} · headroom ${fmt(n.headroom)}%` : "-"],
+  ];
+  const sub = pinned
+    ? `candidate <b>${esc(best.id)}</b> <span class="vchip ${(VMAP[best.verdict]||["","v-noise"])[1]}">${esc(best.verdict)}</span>`
+    : vchip(n);
+  let h = `<div class="dhead"><div class="id">${esc(D.spec)} · ${pinned ? "candidate dossier" : "node dossier"}</div>
+    <h3>${esc(n.fn)} ${sub}</h3></div><div class="dbody">
+    <dl class="kv">${kv.map(([k,v]) => `<dt>${k}</dt><dd>${v}</dd>`).join("")}</dl>`;
+  if (best.hypothesis)
+    h += `<div class="dsec"><h4>hypothesis: the agent's claim, verbatim</h4>
+          <div class="quote">${esc(best.hypothesis)}</div></div>`;
+  if (best.diff)
+    h += `<div class="dsec"><h4>patch · diff: what a human reviews before merging</h4>${diffHtml(best.diff)}</div>`;
+  const critic = best.critic;
+  if (critic && (critic.reasons || []).length)
+    h += `<div class="dsec"><h4>critic audit: the second judge</h4>` +
+         critic.reasons.map(r => `<div class="critic-r"><span class="rub">[${esc(r.rubric)}]</span> ${esc(r.finding)}</div>`).join("") + `</div>`;
+  else if (critic)
+    h += `<div class="dsec"><h4>critic audit</h4><div class="quote">verdict: ${esc(critic.verdict)}</div></div>`;
+  if ((n.reflect || []).length)
+    h += `<div class="dsec"><h4>reflect directions: where the tree grows</h4><ul class="dirs">` +
+         n.reflect.map(r => `<li><span class="st${r.tried?" tried":""}">${r.tried?"tried":"open"}</span><span>${esc(r.text || r)}</span></li>`).join("") +
+         `</ul></div>`;
+  if ((best.notes || []).length)
+    h += `<div class="dsec"><h4>judge notes: verbatim</h4><div class="notes">${esc(best.notes.join("\n"))}</div></div>`;
+  h += `</div>`;
+  doss.innerHTML = h;
+}
+
+renderTree();
+renderDossier(fnNodes[selIdx]);
+
+/* ---------------- closure proof ---------------- */
+(function(){
+  const C = D.closure;
+  const el = document.getElementById("proof");
+  if (!C || !C.boundaries){ document.getElementById("proofsec").style.display = "none"; return; }
+  const [b1, b2, b3] = C.boundaries;
+  const card = (b, title, body) => `<div class="pcard">
+    <div class="st ${b.closed ? "closed" : "open"}">${b.closed ? "closed ✓" : "open"}</div>
+    <h4>${title}</h4><p>${body}</p></div>`;
+  el.innerHTML =
+    card(b1, "Untouchable floor",
+      `<b>${fmt(b1.floor_pct)}%</b> proven not-ours (crypto / runtime): the asymptote no attempt can cross.`) +
+    card(b2, "Measurement floor",
+      b2.closed
+        ? `No open noise-limited cases${(b2.rescued||[]).length ? ` · <b>${b2.rescued.length}</b> rescued by qualified micro-benches (${b2.rescued.map(esc).join(", ")})` : ""}.`
+        : `Open cases: <b>${(b2.open_cases||[]).map(esc).join(", ")}</b>: probe factory queue.`) +
+    card(b3, "Coverage closure",
+      b3.closed ? "Workload factory dry: no proposal adds frontier mass."
+                : `State: <b>${esc(b3.state)}</b>: the workload factory (L4b) opens this axis.`) +
+    "";
+})();
+
+/* ---------------- perf svg (speedup vs tokens) ---------------- */
+if (D.perf_svg){
+  document.getElementById("perfsec").style.display = "";
+  document.getElementById("perfsvg").innerHTML = D.perf_svg;
+}
+</script>
+</body>
+</html>
