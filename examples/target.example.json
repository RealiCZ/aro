{
  "name": "<target-name>",
  "repo": "/absolute/path/to/your/repo",
  "baseline_ref": "HEAD",
  "build": ["cargo", "build", "--release", "-p", "<crate>"],
  "test":  ["cargo", "test", "--release", "-p", "<crate>"],
  "bench": {"probe": "probes/<name>.rs", "example": "<name>", "pkg": "<crate>", "sample_prefix": "BENCH", "metric": "ns_per_call"},
  "profile": {"example": "<name>", "spin_secs": 8, "sample_secs": 4},
  "regions": ["<crate>/src/<hot_file>.rs"],
  "context": {"file": "<crate>/src/<hot_file>.rs", "anchors": [["fn", "<hot_fn>"]]},
  "objectives": [{"metric": "ns_per_call", "minimize": true}],
  "goal": {"metric": "ns_per_call", "direction": "minimize", "target": null},
  "stop": {"max_rounds": 3, "dry_rounds": 2},
  "prompts": {"agentic": "agentic", "hint": "hint", "hint_blind": "hint_blind"},
  "generator": "agentic",
  "differential": {"probe": "probes/<name>_diff.rs", "pkg": "<crate>", "example": "<name>_diff", "prefix": "DIFF"},
  "timeout": 1800
}
